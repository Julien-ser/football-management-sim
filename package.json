{
  "name": "football-management-sim",
  "version": "0.1.0",
  "description": "A strategic football management simulation game",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "tsc --watch",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "vite": "vite",
    "build:web": "vite build",
    "preview": "vite preview",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "test:e2e": "cypress run",
    "test:all": "npm run test && npm run test:e2e",
    "benchmark": "npm run benchmark:match && npm run benchmark:memory",
    "benchmark:match": "bash scripts/benchmark/match-simulation.sh",
    "benchmark:memory": "bash scripts/benchmark/memory-usage.sh"
  },
  "keywords": [
    "football",
    "manager",
    "simulation",
    "game"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@cypress/vite-dev-server": "^7.2.1",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "cypress": "^15.12.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^30.3.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rxjs": "^7.8.2"
  }
}
